<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Acción del Reporte -->
    <record id="action_report_tms_waybill" model="ir.actions.report">
        <field name="name">Cotización de Flete / Carta Porte</field>
        <field name="model">tms.waybill</field>
        <field name="report_type">qweb-pdf</field>
        <!-- CRÍTICO: Debe coincidir con el ID del template (module.template_id) -->
        <field name="report_name">tms.report_tms_waybill_document</field>
        <field name="report_file">tms.report_tms_waybill_document</field>
        <!-- Nombre del archivo descargado -->
        <field name="print_report_name">'Cotizacion - %s' % (object.name).replace('/', '')</field>
        <field name="binding_model_id" ref="model_tms_waybill"/>
        <field name="binding_type">report</field>
    </record>

    <!-- 2. Template QWeb -->
    <template id="report_tms_waybill_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- HEADER: TÍTULO Y ESTADO -->
                        <div class="row mb-4">
                            <div class="col-8">
                                <h2>
                                    <span t-if="o.state == 'cotizado'">Pre-Cotización</span>
                                    <span t-elif="o.state == 'aprobado'">Cotización Aprobada</span>
                                    <span t-else="">Carta Porte / Viaje</span>
                                    <span class="text-muted" t-field="o.name"/>
                                </h2>
                                <p class="text-muted"><span t-field="o.date_created"/></p>
                            </div>
                            <div class="col-4 text-end">
                                <span class="badge rounded-pill text-bg-primary" style="font-size: 14px;" t-field="o.state"/>
                            </div>
                        </div>

                        <!-- BLOQUE 1: ACTORES (3 columnas) -->
                        <div class="row mb-4 pb-3" style="border-bottom: 2px solid #eee;">
                            <!-- Facturación -->
                            <div class="col-4">
                                <strong style="color: #212529; font-size: 1.1em;">Cliente Facturación</strong><br/>
                                <span t-field="o.partner_invoice_id.name"/><br/>
                                <span t-if="o.invoice_rfc">RFC: <span t-field="o.invoice_rfc"/><br/></span>
                                <small t-field="o.invoice_address"/>
                            </div>
                            <!-- Origen -->
                            <div class="col-4">
                                <strong style="color: #212529; font-size: 1.1em;">Origen</strong><br/>
                                <t t-if="o.partner_origin_id">
                                    <span t-field="o.partner_origin_id.name"/><br/>
                                </t>
                                <t t-if="o.origin_city_name">
                                    <span t-out="o.origin_city_name"/><br/>
                                </t>
                                <t t-if="o.origin_zip">
                                    <span>CP <span t-field="o.origin_zip"/></span><br/>
                                </t>
                                <small t-if="o.origin_address" t-field="o.origin_address"/>
                            </div>
                            <!-- Destino -->
                            <div class="col-4">
                                <strong style="color: #212529; font-size: 1.1em;">Destino</strong><br/>
                                <t t-if="o.partner_dest_id">
                                    <span t-field="o.partner_dest_id.name"/><br/>
                                </t>
                                <t t-if="o.dest_city_name">
                                    <span t-out="o.dest_city_name"/><br/>
                                </t>
                                <t t-if="o.dest_zip">
                                    <span>CP <span t-field="o.dest_zip"/></span><br/>
                                </t>
                                <small t-if="o.dest_address" t-field="o.dest_address"/>
                            </div>
                        </div>

                        <!-- BLOQUE 2: DETALLES DEL VIAJE (2 columnas) -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <div class="card p-3" style="background-color: #f8f9fa; border: none;">
                                    <strong><i class="fa fa-map-signs"/> Ruta:</strong> <span t-field="o.route_name"/><br/>
                                    <strong><i class="fa fa-road"/> Distancia:</strong> <span t-field="o.distance_km"/> km<br/>
                                    <strong><i class="fa fa-clock-o"/> Duración:</strong> <span t-field="o.duration_hours"/> hrs
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card p-3" style="background-color: #f8f9fa; border: none;">
                                    <strong><i class="fa fa-truck"/> Vehículo:</strong> <span t-field="o.vehicle_id.license_plate"/> <small>(<span t-field="o.vehicle_id.model_id.name"/>)</small><br/>
                                    <strong><i class="fa fa-user"/> Chofer:</strong> <span t-field="o.driver_id.name"/><br/>
                                    <span t-if="o.trailer1_id"><strong>Remolque 1:</strong> <span t-field="o.trailer1_id.license_plate"/></span>
                                </div>
                            </div>
                        </div>

                        <!-- BLOQUE 3: MERCANCÍAS -->
                        <h5 class="mb-3 border-bottom pb-2">Mercancías</h5>
                        <table class="table table-sm table-striped mb-5">
                            <thead class="table-dark">
                                <tr>
                                    <th>Descripción</th>
                                    <th class="text-end">Cantidad</th>
                                    <th>Unidad</th>
                                    <th class="text-end">Peso (Kg)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="l">
                                    <td>
                                        <span t-field="l.description"/>
                                        <br/><small class="text-muted" t-field="l.product_sat_id.name"/>
                                    </td>
                                    <td class="text-end"><span t-field="l.quantity"/></td>
                                    <td><span t-field="l.uom_sat_id.name"/></td>
                                    <td class="text-end"><span t-field="l.weight_kg"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- BLOQUE 4: TOTALES (Derecha) -->
                        <div class="row justify-content-end">
                            <div class="col-5">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Subtotal:</strong></td>
                                        <td class="text-end"><span t-field="o.amount_untaxed"/></td>
                                    </tr>
                                    <tr>
                                        <td>IVA (16%):</td>
                                        <td class="text-end"><span t-field="o.amount_tax"/></td>
                                    </tr>
                                    <tr class="text-danger">
                                        <td>Retención (4%):</td>
                                        <td class="text-end">- <span t-field="o.amount_retention"/></td>
                                    </tr>
                                    <tr class="border-top">
                                        <td><h4 class="mt-2">Total:</h4></td>
                                        <td class="text-end"><h4 class="mt-2 text-primary" t-field="o.amount_total"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- FIRMAS (si está firmado) -->
                        <div class="row mt-5" t-if="o.signature">
                             <div class="col-6 offset-6 text-center">
                                <img t-att-src="image_data_uri(o.signature)" style="max-height: 100px;"/><br/>
                                <div class="border-top pt-2">
                                    <strong>Aceptado por:</strong> <span t-field="o.signed_by"/><br/>
                                    <small><span t-field="o.signed_on"/></small>
                                </div>
                             </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
