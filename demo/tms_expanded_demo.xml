        <!-- ==================================================== -->
        <!-- 4 DESTINOS (TMS.DESTINATION - RUTAS)               -->
        <!-- ==================================================== -->
        <!-- Corregido: tms.destination es 'Rutas', usa ZIPs, no partner_id directo. 
             Uso los zips de los clientes creados arriba:
             Monterrey (NL): 64000
             Guadalajara (JAL): 44000
             CDMX (DF): 06000
             Leon (GTO): 37000
        -->
        <record id="demo_destination_1" model="tms.destination">
            <!-- Planta MTY (64000) -> CEDIS GDL (44000) -->
            <field name="origin_zip">64000</field>
            <field name="dest_zip">44000</field>
            <field name="vehicle_type_id" ref="tms.tms_vehicle_type_tractor"/>
            <field name="distance_km">800</field>
            <field name="duration_hours">10</field>
            <field name="cost_tolls">3500.00</field>
            <field name="notes">Ruta para Cliente: Logística del Norte</field>
        </record>

