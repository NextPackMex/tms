<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tms_load_demo_wizard_form" model="ir.ui.view">
        <field name="name">tms.load.demo.wizard.form</field>
        <field name="model">tms.load.demo.wizard</field>
        <field name="arch" type="xml">
            <form string="Cargar Datos Demo TMS">
                <group>
                    <div class="alert alert-info" role="alert" style="margin-bottom:0px;">
                        <field name="message" nolabel="1"/>
                    </div>
                </group>
                <footer>
                    <button string="Cargar Datos Demo" name="action_load_demo_data" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tms_load_demo_wizard" model="ir.actions.act_window">
        <field name="name">Cargar Datos Demo</field>
        <field name="res_model">tms.load.demo.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menú item en Configuración -->
    <menuitem id="menu_tms_load_demo" name="Cargar Datos Demo" parent="menu_tms_config" action="action_tms_load_demo_wizard" sequence="99"/>
</odoo>
