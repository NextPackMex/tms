                                    <span style="font-size:20px;line-height:1;">🏢</span>
                                    <div>
                                        <div style="font-size:11px;font-weight:600;color:#664d03;">RFC Emisor</div>
                                        <div style="font-size:10px;color:#856404;">Auto-sustituido ℹ</div>
                                    </div>
                                </div>
                            </div>
                            <!-- 🏢 RFC Emisor — verde (PRODUCCION) -->
                            <div class="col-6" invisible="ambiente == 'PRUEBAS' or not val_emisor_rfc">
                                <div style="background:#d1e7dd;border-radius:8px;padding:6px 10px;display:flex;align-items:center;gap:8px;">
