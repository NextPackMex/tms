<?xml version="1.0" encoding="utf-8"?>
<!-- Wizard de validación previa al timbrado de Carta Porte 3.1 (V2.2.2)
     Odoo 19: t-set/t-attf-style son directivas OWL prohibidas en arch.
     Patrón alternativo: 2-3 versiones de cada tarjeta con invisible= toggle. -->
<odoo>

    <record id="view_tms_stamp_validation_wizard_form" model="ir.ui.view">
        <field name="name">tms.stamp.validation.wizard.form</field>
        <field name="model">tms.stamp.validation.wizard</field>
        <field name="arch" type="xml">
            <form string="Validación previa al timbrado">
                <sheet>

                    <!-- ── Badges de ambiente ─────────────────────────────── -->
                    <div class="alert alert-warning mb-1 py-1 px-2"
                         role="status"
                         style="font-size:13px;"
                         invisible="ambiente != 'PRUEBAS'">
                        <strong>⚠ PRUEBAS</strong> —
                        RFC de emisor, receptor y chofer se sustituyen automáticamente.
                        Los campos en amarillo son informativos.
                    </div>
                    <div class="alert alert-success mb-1 py-1 px-2"
                         role="status"
                         style="font-size:13px;"
                         invisible="ambiente != 'PRODUCCION'">
                        <strong>🌐 PRODUCCIÓN</strong> —
                        Se usarán los datos fiscales reales de la empresa.
                    </div>

                    <!-- ── Estado general ─────────────────────────────────── -->
                    <div class="alert alert-danger mb-1 py-1 px-2"
                         role="alert"
                         style="font-size:13px;"
                         invisible="puede_timbrar">
                        <strong>❌ No se puede timbrar todavía.</strong>
                        Corrige los campos en rojo y vuelve a intentarlo.
                    </div>
                    <div class="alert alert-success mb-1 py-1 px-2"
                         role="status"
                         style="font-size:13px;"
                         invisible="not puede_timbrar">
                        <strong>✅ Todo listo.</strong>
                        Presiona "Timbrar Carta Porte" para continuar.
                    </div>

                    <!-- ── Viaje ──────────────────────────────────────────── -->
                    <group class="mb-1">
                        <field name="waybill_id" readonly="1"/>
                    </group>

                    <!-- ════════════════════════════════════════════════════
                         GRILLA DE TARJETAS — 2 columnas
                         Cada campo tiene 2-3 versiones de tarjeta con invisible=:
                           - Regular: version-ok (verde) + version-fail (rojo)
                           - INFO (auto-sustituido en PRUEBAS): +version-info (amarillo)
                         Solo 2 tarjetas son visibles en cada fila en todo momento.
                    ════════════════════════════════════════════════════ -->
                    <div class="container-fluid px-0">

                        <!-- ── SECCIÓN: Empresa emisora ────────────────── -->
                        <div class="row mb-0 mt-1">
                            <div class="col-12">
                                <small class="text-muted text-uppercase fw-bold"
                                       style="font-size:10px;letter-spacing:0.05em;">
                                    Empresa emisora
                                </small>
                                <hr class="mt-0 mb-1" style="border-color:#dee2e6;"/>
                            </div>
                        </div>

                        <!-- Fila 1: 🔐 Certificado CSD | 🗝️ Llave Privada CSD -->
                        <div class="row g-1 mb-1">

                            <!-- 🔐 CSD cert — verde -->
                            <div class="col-6" invisible="not val_emisor_cer">
                                <div style="background:#d1e7dd;border-radius:8px;padding:6px 10px;display:flex;align-items:center;gap:8px;">
                                    <span style="font-size:20px;line-height:1;">🔐</span>
                                    <div>
                                        <div style="font-size:11px;font-weight:600;color:#0a3622;">Certificado CSD</div>
                                        <div style="font-size:10px;color:#146c43;">Cargado ✓</div>
                                    </div>
                                </div>
                            </div>
                            <!-- 🔐 CSD cert — rojo -->
                            <div class="col-6" invisible="val_emisor_cer">
                                <div style="background:#f8d7da;border-radius:8px;padding:6px 10px;display:flex;align-items:center;gap:8px;">
                                    <span style="font-size:20px;line-height:1;">🔐</span>
                                    <div>
                                        <div style="font-size:11px;font-weight:600;color:#58151c;">Certificado CSD</div>
                                        <div style="font-size:10px;color:#842029;">No encontrado ✗</div>
                                    </div>
                                </div>
                            </div>

                            <!-- 🗝️ CSD key — verde -->
                            <div class="col-6" invisible="not val_emisor_key">
                                <div style="background:#d1e7dd;border-radius:8px;padding:6px 10px;display:flex;align-items:center;gap:8px;">
                                    <span style="font-size:20px;line-height:1;">🗝️</span>
                                    <div>
                                        <div style="font-size:11px;font-weight:600;color:#0a3622;">Llave Privada CSD</div>
                                        <div style="font-size:10px;color:#146c43;">Cargada ✓</div>
                                    </div>
                                </div>
                            </div>
                            <!-- 🗝️ CSD key — rojo -->
                            <div class="col-6" invisible="val_emisor_key">
                                <div style="background:#f8d7da;border-radius:8px;padding:6px 10px;display:flex;align-items:center;gap:8px;">
