<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        ================================================================
        EXTENSIÓN DE VISTAS DE FLEET.VEHICLE
        ================================================================

        VENTAJAS DE HEREDAR EL MÓDULO NATIVO:
        - Aprovechamos TODAS las vistas existentes de Fleet
        - No duplicamos código
        - Los usuarios ven la interfaz familiar de Odoo
        - Mantenimiento, costos, contratos ya funcionan automáticamente

        ESTRATEGIA:
        - Heredamos la vista form de fleet
        - Agregamos nuestros campos en una pestaña nueva
        - Usamos invisible para ocultar campos según tipo (tractor/remolque)
    -->

    <!--
        ================================================================
        EXTENSIÓN DE FORM VIEW - Agregar pestaña "Configuración TMS" ================================================================
    -->
    <!--
        ================================================================
        VISTA FORM SIMPLIFICADA PARA TRACTORES (TMS)
        ================================================================
    -->
    <record id="view_tms_vehicle_tractor_form" model="ir.ui.view">
        <field name="name">tms.fleet.vehicle.tractor.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Tractocamión">
                <sheet>
                    <div class="oe_title">
                        <label for="model_id"/>
                        <h1>
                            <field name="model_id" placeholder="Ej. Volvo FH16"/>
                        </h1>
                        <label for="license_plate"/>
                        <h2>
                            <field name="license_plate" class="oe_inline" placeholder="ABC-123-A"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Identificación TMS">
                            <field name="no_economico" placeholder="ECO-001"/>
                            <field name="tms_vehicle_type_id" options="{'no_create': True}"/>
                            <field name="model_year"/>
                        </group>
                        <group string="Configuración SAT (Carta Porte)">
                            <field name="sat_config_id" required="1"/>
                            <field name="sat_permiso_sct_id" required="1"/>
                            <field name="permiso_sct_number" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Seguros y Pesos" name="insurance">
                            <group>
                                <group string="Seguro Civil (Obligatorio)">
                                    <field name="tms_insurance_civil_liability_mx" required="1"/>
                                    <field name="tms_insurance_civil_liability" required="1"/>
                                </group>
                                <group string="Pesos y Casetas">
                                    <field name="tms_gross_vehicle_weight" string="Peso Bruto (Ton)"/>
                                    <field name="num_axles"/>
                                    <field name="tms_num_axles"/>
                                    <field name="tms_fuel_performance"/>
                                    <field name="performance_km_l"/>
                                </group>
                            </group>
                        </page>
                        <page string="Remolques por Defecto" name="trailers">
                            <group>
                                <field name="trailer1_id"/>
                                <field name="trailer2_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--
        ================================================================
        VISTA FORM SIMPLIFICADA PARA REMOLQUES (TMS)
        ================================================================
    -->
    <record id="view_tms_vehicle_trailer_form" model="ir.ui.view">
        <field name="name">tms.fleet.vehicle.trailer.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Remolque">
                <sheet>
                    <div class="oe_title">
                        <label for="model_id" string="Tipo de Remolque"/>
                        <h1>
                            <field name="model_id" placeholder="Ej. Caja Seca 53ft"/>
                        </h1>
                        <label for="license_plate"/>
                        <h2>
                            <field name="license_plate" class="oe_inline" placeholder="ABC-123-A"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Identificación">
                            <field name="no_economico"/>
                            <field name="tms_vehicle_type_id" options="{'no_create': True}"/>
                            <field name="model_year"/>
                        </group>
                        <group string="Configuración SAT">
                            <field name="sat_config_id" string="SubTipo Remolque SAT" required="1"/>
                            <field name="tms_gross_vehicle_weight" string="Peso (Ton)"/>
                            <field name="tms_num_axles"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VISTAS LIST (TREE) SIMPLIFICADAS -->
    <record id="view_tms_vehicle_tractor_list" model="ir.ui.view">
        <field name="name">tms.fleet.vehicle.tractor.list</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <list string="Tractocamiones">
                <field name="no_economico"/>
                <field name="model_id"/>
                <field name="license_plate"/>
                <field name="sat_config_id"/>
                <field name="tms_insurance_civil_liability_mx"/>
            </list>
        </field>
    </record>

    <record id="view_tms_vehicle_trailer_list" model="ir.ui.view">
        <field name="name">tms.fleet.vehicle.trailer.list</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <list string="Remolques">
                <field name="no_economico"/>
                <field name="model_id"/>
                <field name="license_plate"/>
                <field name="sat_config_id" string="SubTipo SAT"/>
            </list>
        </field>
    </record>

    <!--
        ================================================================
        ACCIÓN: VEHÍCULOS (Solo Tractores)
        ================================================================
    -->
    <record id="action_tms_vehicles" model="ir.actions.act_window">
        <field name="name">Vehículos (Tractores)</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('tms_is_trailer', '=', False)]</field>
        <field name="context">{'default_tms_is_trailer': False, 'default_is_trailer': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_tms_vehicle_tractor_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_tms_vehicle_tractor_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Agregar un vehículo
            </p>
            <p>
                Registra tractocamiones y camiones unitarios.
            </p>
        </field>
    </record>

    <!--
        ================================================================
        ACCIÓN: REMOLQUES
        ================================================================
    -->
    <record id="action_tms_trailers" model="ir.actions.act_window">
        <field name="name">Remolques</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('tms_is_trailer', '=', True)]</field>
        <field name="context">{'default_tms_is_trailer': True, 'default_is_trailer': False}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_tms_vehicle_trailer_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_tms_vehicle_trailer_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Agregar un remolque
            </p>
            <p>
                Registra remolques y semirremolques.
            </p>
        </field>
    </record>

</odoo>

