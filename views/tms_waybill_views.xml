<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================= -->
    <!-- VISTA KANBAN (DASHBOARD) -->
    <!-- ======================= -->
    <record id="view_tms_waybill_kanban" model="ir.ui.view">
        <field name="name">tms.waybill.kanban</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" records_draggable="true">
                <field name="name"/>
                <field name="state"/>
                <field name="currency_id"/>
                <field name="waybill_type"/>
                <field name="partner_invoice_id"/>
                <field name="amount_total"/>
                <field name="route_name"/>
                <field name="date_created"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="text-muted">
                                        <field name="partner_invoice_id"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <span class="badge text-bg-success">
                                    <field name="amount_total" widget="monetary"/>
                                </span>
                                <div class="text-muted small mt-1">
                                    <field name="route_name"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <span class="text-muted small">
                                        <field name="date_created"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <t t-if="record.waybill_type.raw_value == 'income'">
                                        <span class="badge text-bg-info">
                                            Ingreso
                                        </span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ======================= -->
    <!-- VISTA LIST (TABLA) -->
    <!-- ======================= -->
    <record id="view_tms_waybill_tree" model="ir.ui.view">
        <field name="name">tms.waybill.list</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <list string="Viajes">
                <field name="name"/>
                <field name="date_created"/>
                <field name="partner_invoice_id"/>
                <field name="route_name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="amount_total" widget="monetary"/>
                <!-- decoration-success: estado 'closed' (Facturado/Cerrado) resaltado en verde -->
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'closed'"/>
                <field name="company_id" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ======================= -->
    <!-- FORMULARIO CON COTIZADOR (SIN CHATTER) -->
    <!-- ======================= -->
    <record id="view_tms_waybill_form" model="ir.ui.view">
        <field name="name">tms.waybill.form</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <form string="Viaje">
                <header>
                    <button name="action_preview_waybill" string="Vista Previa" type="object" class="btn-secondary" icon="fa-globe"/>
                    <button name="action_assign" string="Confirmar (Por Asignar)" type="object" class="oe_highlight" invisible="state not in ['draft', 'en_pedido']"/>
                    <button name="action_set_en_pedido" string="Confirmar Pedido" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_send_email" string="Enviar Cotización" type="object" class="btn-primary" icon="fa-envelope" invisible="state != 'draft'"/>
                    <!-- Botón Generar Carta Porte: solo visible cuando estado es 'assigned' (Por Asignar) -->
                    <button name="action_approve_cp" string="Generar Carta Porte" type="object" class="oe_highlight" invisible="state != 'assigned'"/>
                    <!-- Botón Iniciar Ruta: solo visible cuando estado es 'waybill' (Carta Porte Lista) -->
                    <button name="action_start_route_manual" string="Iniciar Ruta" type="object" class="oe_highlight" invisible="state != 'waybill'"/>
                    <!-- Botón Registrar Llegada: solo visible cuando estado es 'in_transit' (En Trayecto) -->
                    <button name="action_arrived_dest_manual" string="Registrar Llegada" type="object" class="oe_highlight" invisible="state != 'in_transit'"/>
                    <!-- Botón Facturar: solo visible cuando estado es 'arrived' (En Destino) -->
                    <button name="action_create_invoice" string="Facturar" type="object" class="oe_highlight" invisible="state != 'arrived'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,en_pedido,assigned,waybill,in_transit,arrived,closed" statusbar_colors="draft:grey;en_pedido:blue;assigned:orange;waybill:green;in_transit:purple;arrived:teal;closed:black"/>
                </header>

                <sheet>
                    <field name="company_id" invisible="1"/>
                    <field name="is_fuel_price_outdated" invisible="1"/>
                    <div class="alert alert-warning" role="alert" invisible="not is_fuel_price_outdated">
                        <strong>AVISO:</strong> No hay precio de diesel reciente (más de 7 días) o no existe historial. Se utiliza el último registro disponible.
                    </div>
                    <div class="d-flex justify-content-between">
                        <div class="oe_title">
                            <label for="name" string="Folio"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <div class="text-center">
                            <div class="d-flex gap-3">
                                <div>
                                    <label for="date_started_route" string="Fecha Y hora Embarque" class="text-danger fw-bold"/>
                                    <h3 class="m-0">
                                        <field name="date_started_route" widget="datetime" class="text-danger" nolabel="1"/>
                                    </h3>
                                </div>
                                <div>
                                    <label for="date_arrived_dest" string="Fecha y hora de Entrega" class="text-danger fw-bold"/>
                                    <h3 class="m-0">
                                        <field name="date_arrived_dest" widget="datetime" class="text-danger" nolabel="1"/>
                                    </h3>
                                </div>
                            </div>
                        </div>

                        <div class="oe_title text-end">
                            <label for="company_name" string="Empresa"/>
                            <h1>
                                <field name="company_name" readonly="1" class="text-danger"/>
                            </h1>

                        </div>
                    </div>

                    <!-- Datos generales + resumen de precio -->
                    <!-- SECCIÓN DE BÚSQUEDA Y RUTA (OPTIMIZADO PARA ANCHO) -->
                    <!-- DATOS GENERALES Y DETALLES -->
                    <!-- ACTORES DEL VIAJE (HEADER) -->
                    <div class="row mb-3">
                        <div class="col-lg-8">
                            <!-- FACTURACIÓN CARD -->
                            <div class="card shadow-sm p-3 bg-white" style="border: 1px solid #e0e0e0;">
                                <group string="Facturación" class="mb-0">
                                    <field name="date_created" string="Fecha del Pedido"/>
                                    <field name="partner_invoice_id" required="state != 'draft'"/>
                                    <field name="invoice_rfc" readonly="1"/>
                                    <field name="invoice_address" readonly="1"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                                <div class="text-end mt-2">
                                    <button name="action_clear_facturacion" type="object" icon="fa-trash" title="Limpiar" class="btn btn-link text-danger"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <!-- PRECIO CARD -->
                            <div class="card shadow-sm p-3 bg-white h-100" style="border: 1px solid #e0e0e0;">
                                <group class="mb-0">
                                    <field name="amount_untaxed" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_tax" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_retention" widget="monetary" options="{'currency_field': 'currency_id'}" class="text-danger"/>
                                    <label for="amount_total" string="Precio Final"/>
                                    <h2>
                                        <field name="amount_total" widget="monetary" decoration-danger="amount_total == 0"/>
                                    </h2>
                                    <field name="selected_proposal" string="Propuesta" widget="label" class="text-muted"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-lg-6">
                            <!-- ORIGEN CARD -->
                            <div class="card shadow-sm p-3 bg-white h-100" style="border: 1px solid #e0e0e0;">
                                <group string="Origen" class="mb-0">
                                    <field name="partner_origin_id" required="state != 'draft'"/>
                                    <field name="origin_address" required="state != 'draft'"/>
                                    <field name="origin_zip" required="state != 'draft'"/>
                                    <field name="origin_rfc"/>
                                </group>
                                <div class="text-end mt-2">
                                    <button name="action_clear_origen" type="object" icon="fa-trash" title="Limpiar" class="btn btn-link text-danger"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <!-- DESTINO CARD -->
                            <div class="card shadow-sm p-3 bg-white h-100" style="border: 1px solid #e0e0e0;">
                                <group string="Destino" class="mb-0">
                                    <field name="partner_dest_id" required="state != 'draft'"/>
                                    <field name="dest_address" required="state != 'draft'"/>
                                    <field name="dest_zip" required="state != 'draft'"/>
                                    <field name="dest_rfc"/>
                                </group>
                                <div class="text-end mt-2">
                                    <button name="action_clear_destino" type="object" icon="fa-trash" title="Limpiar" class="btn btn-link text-danger"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <notebook>
                        <!-- ======================= -->
                        <!-- INFO GENERAL -->
                        <!-- ======================= -->
                        <!-- ======================= -->
                        <!-- INFORMACIÓN DE RUTA    -->
                        <!-- ======================= -->
                        <page string="Información de Ruta">
                            <group>
                                <group invisible="state in ['draft','en_pedido']">
                                    <field name="waybill_type" widget="radio" options="{'horizontal': True}" class="oe_edit_only"/>
                                    <field name="waybill_type" widget="badge" class="oe_read_only" decoration-info="waybill_type == 'income'" decoration-muted="waybill_type == 'transfer'"/>
                                </group>
                            </group>

                            <!-- UNIDAD ASIGNADA -->
                            <group string="Unidad Asignada">
                                <group>
                                    <field name="vehicle_id" required="state != 'draft'"/>
                                    <field name="require_trailer" widget="boolean_toggle"/>
                                    <field name="trailer1_id" invisible="not require_trailer"/>
                                    <field name="dolly_id" invisible="not require_trailer"/>
                                </group>
                                <group>
                                    <field name="driver_id"/>
                                    <field name="trailer2_id" widget="many2one" placeholder="Segundo Remolque (Opcional)"/>
                                    <field name="total_axles"/>
                                </group>
                            </group>

                            <!-- DETALLES DE RUTA -->
                            <group string="Detalles de Ruta">
                                <group>
                                    <field name="distance_km" required="state != 'draft'"/>
                                    <field name="duration_hours" widget="float_time" required="state != 'draft'"/>
                                    <field name="cost_tolls" widget="monetary" required="state != 'draft'"/>
                                </group>
                                <group>
                                    <label for="action_compute_route_smart" string="Cálculo"/>
                                    <div class="o_row">
                                        <button name="action_compute_route_smart" type="object" string=" Calcular Ruta (Smart)" icon="fa-magic" class="btn btn-primary"/>
                                        <div class="text-muted ms-2">
                                            <i class="fa fa-info-circle"/>
 Calcula distancia y casetas basado en Origen/Destino y Vehículo.
                                        </div>
                                    </div>
                                </group>
                            </group>
                        </page>

                        <!-- ======================= -->
                        <!-- COTIZACIÓN Y COSTOS (SIEMPRE VISIBLE) -->
                        <!-- ======================= -->
                        <page string="Cotización y Costos">
                            <group>
                                <group string="Variables de Costo">
                                    <field name="fuel_price_liter"/>
                                    <field name="fuel_performance"/>
                                    <field name="cost_tolls"/>
                                    <field name="cost_driver"/>
                                    <field name="cost_maneuver"/>
                                    <field name="cost_other"/>
                                    <field name="cost_commission"/>
                                    <field name="cost_diesel_total" readonly="1"/>
                                    <field name="cost_total_estimated" decoration-bf="1" readonly="1"/>
                                </group>
                                <group string="Selección de Propuesta">
                                    <!-- label con 'for' para Odoo 18 -->
                                    <label for="selected_proposal" string="Selecciona la propuesta que se aplicará al cliente." class="o_form_label text-muted"/>
                                    <field name="selected_proposal" widget="radio"/>
                                </group>
                            </group>

                            <separator string="Comparativa de Propuestas"/>

                            <group col="3">
                                <!-- Opción A: Por KM -->
                                <group string="🅰️ Por Kilómetro">
                                    <field name="price_per_km"/>
                                    <label for="distance_km" string="Distancia Total"/>
                                    <div class="o_row">
                                        <field name="distance_km" class="oe_inline" readonly="1"/>
 km base +
                                        <field name="extra_distance_km" class="oe_inline"/>
 km extras
                                    </div>
                                    <p class="text-muted small" style="margin-top: 5px;">
                                        <i class="fa fa-info-circle"/>
 Los km extras se suman a la distancia base para el cobro
                                    </p>
                                    <field name="proposal_km_total" widget="monetary" readonly="1" decoration-bf="1"/>
                                </group>

                                <!-- Opción B: Por Viaje -->
                                <group string="Por Costo + Margen">
                                    <field name="profit_margin_percent"/>
                                    <field name="proposal_trip_total" widget="monetary" readonly="1"/>
                                </group>

                                <!-- Opción C: Directa -->
                                <group string="Precio Directo">
                                    <field name="proposal_direct_amount" widget="monetary"/>
                                </group>
                            </group>
                        </page>

                        <!-- ======================= -->
                        <!-- CARTA PORTE 3.1 -->
                        <!-- ======================= -->
                        <page string="Complemento Carta Porte 3.1" name="carta_porte_31">
                            <group>
                                <group string="Identificación">
                                    <label for="tms_id_ccp"/>
                                    <div class="d-flex gap-2">
                                        <field name="tms_id_ccp" placeholder="Automático al timbrar"/>
                                        <button name="action_generate_id_ccp" type="object" string="Generar ID" class="btn-secondary" invisible="tms_id_ccp" help="Genera el UUID requerido para el IdCCP"/>
                                    </div>
                                    <field name="l10n_mx_edi_is_international" widget="boolean_toggle"/>
                                    <field name="l10n_mx_edi_logistica_inversa" widget="boolean_toggle"/>
                                </group>
                                <group string="Autotransporte">
                                    <field name="tms_gross_vehicle_weight" string="Peso Bruto (Ton)"/>
                                </group>
                            </group>

                            <group string="Regímenes Aduaneros (Hasta 10)" invisible="not l10n_mx_edi_is_international">
                                <field name="l10n_mx_edi_customs_regime_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="regimen_aduanero"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                        <!-- ======================= -->
                        <!-- MERCANCÍAS             -->
                        <!-- ======================= -->
                        <page string="Mercancías">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_sat_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="uom_sat_id"/>
                                    <field name="weight_kg"/>
                                    <field name="dimensions"/>
                                    <field name="is_dangerous"/>
                                    <field name="material_peligroso_id" invisible="not is_dangerous" required="is_dangerous"/>
                                    <field name="embalaje_id" optional="show"/>
                                    <field name="l10n_mx_edi_tax_object"/>
                                    <field name="l10n_mx_edi_sector_cofepris" optional="hide"/>
                                    <field name="l10n_mx_edi_active_ingredient" optional="hide"/>
                                    <field name="l10n_mx_edi_nominal_purity" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <!-- ======================= -->
                        <!-- BITÁCORA GPS           -->
                        <!-- ======================= -->
                        <page string="Bitácora GPS">
                            <field name="tracking_event_ids">
                                <list string="Eventos de Rastreo" editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="location_description"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                    <field name="source" widget="badge" decoration-info="source == 'app'" decoration-muted="source == 'manual'"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                                <form string="Evento de Rastreo">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="date"/>
                                                <field name="name"/>
                                                <field name="source"/>
                                            </group>
                                            <group>
                                                <field name="latitude"/>
                                                <field name="longitude"/>
                                                <field name="location_description"/>
                                            </group>
                                        </group>
                                        <field name="notes" placeholder="Notas adicionales..."/>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <!-- ======================= -->
                        <!-- FIRMA DIGITAL          -->
                        <!-- ======================= -->
                        <page string="Firma Digital" invisible="not signature">
                            <group>
                                <group string="Detalles de la Firma">
                                    <field name="signed_by" readonly="1"/>
                                    <field name="signed_on" readonly="1"/>
                                    <field name="signed_ip" readonly="1"/>
                                    <label for="signed_latitude" string="Ubicación Firma"/>
                                    <div class="o_row">
                                        <field name="signed_latitude" readonly="1" class="oe_inline"/>
 /
                                        <field name="signed_longitude" readonly="1" class="oe_inline"/>
                                        <a type="action" class="btn btn-sm btn-link" role="button" target="_blank" href="https://www.google.com/maps/search/?api=1&amp;query={{signed_latitude}},{{signed_longitude}}" invisible="not signed_latitude">
                                            <i class="fa fa-map-marker"/>
 Ver en Mapa
                                        </a>
                                    </div>
                                </group>
                                <group string="Imagen de Firma">
                                    <field name="signature" widget="signature" readonly="1" style="max-height: 200px;"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- ======================= -->
    <!-- SEARCH Y ACTION -->
    <!-- ======================= -->
    <record id="view_tms_waybill_search" model="ir.ui.view">
        <field name="name">tms.waybill.search</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_invoice_id"/>
                <!-- Filtro: muestra solo viajes en estado 'draft' (Solicitud/Borrador) -->
                <filter name="filter_request" string="Solicitudes" domain="[('state', '=', 'draft')]"/>
                <!--
                <group expand="0" string="Agrupar Por">
                    <filter string="Estado" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
                -->
            </search>
        </field>
    </record>

    <record id="action_tms_waybill" model="ir.actions.act_window">
        <field name="name">Viajes / Tablero</field>
        <field name="res_model">tms.waybill</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_tms_waybill_search"/>
        <field name="context">{'search_default_group_by_state': 1}</field>
    </record>

</odoo>
