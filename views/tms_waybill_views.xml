<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================= -->
    <!-- VISTA KANBAN (DASHBOARD) -->
    <!-- ======================= -->
    <record id="view_tms_waybill_kanban" model="ir.ui.view">
        <field name="name">tms.waybill.kanban</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" records_draggable="true" create="false" on_create="%(tms.action_tms_cotizacion_wizard)d">
                <!-- Campos necesarios para la tarjeta kanban -->
                <field name="name"/>
                <field name="state"/>
                <field name="color"/>
                <field name="priority"/>
                <field name="currency_id"/>
                <field name="waybill_type"/>
                <field name="partner_invoice_id"/>
                <field name="amount_total"/>
                <field name="route_name"/>
                <field name="date_created"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="distance_km"/>
                <field name="duration_hours"/>
                <field name="cfdi_status"/>

                <!-- Definición de colores por valor del campo 'color' -->
                <progressbar field="priority" colors="{&quot;0&quot;: &quot;success&quot;, &quot;1&quot;: &quot;warning&quot;, &quot;2&quot;: &quot;warning&quot;, &quot;3&quot;: &quot;danger&quot;}"/>

                <templates>
                    <t t-name="card">
                        <!-- ============================================================
                             CABECERA: Folio + prioridad (estrellas) + tipo de carta porte
                             ============================================================ -->
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <!-- Folio + estrellas de prioridad -->
                            <div class="o_kanban_record_top mb-1 d-flex justify-content-between align-items-center">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <!-- Estrellas de prioridad -->
                                    <field name="priority" widget="priority"/>
                                    <!-- Badge de tipo -->
                                    <t t-if="record.waybill_type.raw_value == 'income'">
                                        <span class="badge text-bg-info ms-1">Ingreso</span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge text-bg-secondary ms-1">Traslado</span>
                                    </t>
                                </div>
                            </div>

                            <!-- Badge estado CFDI -->
                            <div class="mb-1">
                                <span t-if="record.cfdi_status.raw_value == 'timbrado'"
                                      class="badge rounded-pill text-bg-success">Timbrada</span>
                                <span t-elif="record.state.raw_value == 'aprobado'"
                                      class="badge rounded-pill text-bg-warning">Por Timbrar</span>
                            </div>

                            <!-- ============================================================
                                 CLIENTE
                                 ============================================================ -->
                            <div class="text-muted small mb-2">
                                <i class="fa fa-building me-1" title="Empresa"/>
                                <field name="partner_invoice_id"/>
                            </div>

                            <!-- ============================================================
                                 RUTA: Origen → Destino con distancia/tiempo
                                 ============================================================ -->
                            <div class="o_kanban_record_body mb-2">
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    <i class="fa fa-map-marker text-danger"/>
                                    <span class="small text-muted">
                                        <field name="route_name"/>
                                    </span>
                                </div>
                                <t t-if="record.distance_km.raw_value">
                                    <div class="d-flex gap-3 small text-muted">
                                        <span>
                                            <i class="fa fa-road me-1" title="Ruta"/>
                                            <field name="distance_km"/>
 km</span>
                                        <span>
                                            <i class="fa fa-clock-o me-1" title="Duración"/>
                                            <field name="duration_hours"/>
 h</span>
                                    </div>
                                </t>
                            </div>

                            <!-- ============================================================
                                 VEHÍCULO Y CHOFER
                                 ============================================================ -->
                            <t t-if="record.vehicle_id.raw_value">
                                <div class="d-flex gap-3 small text-muted mb-2">
                                    <span>
                                        <i class="fa fa-truck me-1 text-primary" title="Vehículo"/>
                                        <field name="vehicle_id"/>
                                    </span>
                                    <t t-if="record.driver_id.raw_value">
                                        <span>
                                            <i class="fa fa-user me-1 text-primary" title="Chofer"/>
                                            <field name="driver_id"/>
                                        </span>
                                    </t>
                                </div>
                            </t>

                            <!-- ============================================================
                                 FOOTER: Fecha + Monto
                                 ============================================================ -->
                            <div class="o_kanban_record_bottom mt-2 d-flex justify-content-between align-items-center">
                                <div class="oe_kanban_bottom_left">
                                    <span class="text-muted small">
                                        <i class="fa fa-calendar me-1" title="Fecha"/>
                                        <field name="date_created"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <strong class="text-success">
                                        <i class="fa fa-usd me-1" title="Precio"/>
                                        <field name="amount_total" />
                                    </strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ======================= -->
    <!-- VISTA LIST (TABLA) -->
    <!-- ======================= -->
    <record id="view_tms_waybill_tree" model="ir.ui.view">
        <field name="name">tms.waybill.list</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <list string="Viajes" create="false">
                <header>
                    <button name="%(tms.action_tms_cotizacion_wizard)d" string="Nueva Cotización" type="action" class="btn-primary" icon="fa-plus"/>
                </header>
                <field name="name"/>
                <field name="date_created"/>
                <field name="partner_invoice_id"/>
                <field name="route_name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="amount_total" />
                <!-- decoration-success: estado 'closed' (Facturado/Cerrado) resaltado en verde -->
                <field name="state" widget="badge" decoration-info="state == 'cotizado'" decoration-success="state == 'closed'"/>
                <field name="company_id" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ======================= -->
    <!-- FORMULARIO CON COTIZADOR (SIN CHATTER) -->
    <!-- ======================= -->
    <record id="view_tms_waybill_form" model="ir.ui.view">
        <field name="name">tms.waybill.form</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <form string="Viaje" create="false">
                <header>
                    <button name="action_approve_quotation" string="Aprobar Cotización" type="object" class="btn-primary" invisible="state != 'cotizado'"/>
                    <button name="action_preview_waybill" string="Vista Previa" type="object" class="btn-secondary" icon="fa-globe"/>
                    <button name="action_send_email" string="Enviar Cotización" type="object" class="btn-primary" icon="fa-envelope" invisible="state not in ('cotizado', 'aprobado')"/>
                    <!-- Botón Iniciar Ruta: solo visible cuando estado es 'waybill' (Carta Porte Lista) -->
                    <button name="action_start_route_manual" string="Iniciar Ruta" type="object" class="oe_highlight" invisible="state != 'waybill'"/>
                    <!-- Botón Registrar Llegada: solo visible cuando estado es 'in_transit' (En Trayecto) -->
                    <button name="action_arrived_dest_manual" string="Registrar Llegada" type="object" class="oe_highlight" invisible="state != 'in_transit'"/>
                    <!-- Botón Facturar: solo visible cuando estado es 'arrived' (En Destino) -->
                    <button name="action_create_invoice" string="Facturar" type="object" class="oe_highlight" invisible="state != 'arrived'"/>
                    <!-- Botón Cancelar: disponible en etapas tempranas antes de que salga a ruta -->
                    <button name="action_cancel" string="Cancelar" type="object" class="btn-danger" invisible="state not in ['cotizado','aprobado']" confirm="¿Cancelar este viaje? Esta acción no se puede deshacer."/>

                    <!-- ═══════════════════════════════════════════════════
                         BOTONES CFDI — Timbrado, cancelación y estatus SAT
                         ═══════════════════════════════════════════════════ -->
                    <!-- Timbrar: visible cuando la CP está lista y aún no está timbrada -->
                    <button name="action_stamp_cfdi"
                            string="Timbrar Carta Porte"
                            type="object"
                            class="oe_highlight"
                            icon="fa-stamp"
                            invisible="state not in ('aprobado', 'waybill') or cfdi_status == 'timbrado'"
                            help="Genera y sella el CFDI 4.0 con Complemento Carta Porte 3.1"/>
                    <!-- Cancelar CFDI: solo cuando ya está timbrado -->
                    <button name="action_cancel_cfdi"
                            string="Cancelar CFDI"
                            type="object"
                            class="btn-danger"
                            icon="fa-times-circle"
                            invisible="cfdi_status != 'timbrado'"
                            confirm="¿Cancelar el CFDI ante el SAT? Esta acción no se puede deshacer."/>
                    <!-- Estatus SAT: disponible cuando hay CFDI (timbrado o cancelado) -->
                    <button name="action_check_cfdi_status"
                            string="Estatus SAT"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"
                            invisible="cfdi_status == 'none'"
                            help="Consulta el estatus del CFDI en el SAT"/>
                    <!-- Descargar XML: solo cuando está timbrado -->
                    <button name="action_download_cfdi_xml"
                            string="Descargar XML"
                            type="object"
                            class="btn-secondary"
                            icon="fa-download"
                            invisible="cfdi_status != 'timbrado'"
                            help="Descarga el XML del CFDI timbrado"/>
                    <!-- PDF Carta Porte timbrada: solo cuando está timbrado -->
                    <button name="action_print_carta_porte"
                            string="Carta Porte PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-file-pdf-o"
                            invisible="cfdi_status != 'timbrado'"
                            help="Genera el PDF de la Carta Porte timbrada con QR de verificación SAT"/>

                    <!-- Campo invisible para usar en condiciones de visibilidad -->
                    <field name="cfdi_status" invisible="1"/>

                    <field name="state" widget="statusbar" statusbar_visible="cotizado,aprobado,waybill,in_transit,arrived,closed" statusbar_colors="cotizado:secondary;aprobado:info;waybill:success;in_transit:primary;arrived:warning;closed:dark"/>
                </header>

                <!-- Banner: datos faltantes para timbrar (solo en estado aprobado) -->
                <div class="alert alert-danger mb-0"
                     role="alert"
                     invisible="tms_stamp_ready or state != 'aprobado'">
                    <field name="tms_stamp_ready" invisible="1"/>
                    <field name="tms_stamp_missing" invisible="1"/>
                    <strong>⚠️ Faltan datos para timbrar:</strong>
                    <field name="tms_stamp_missing" readonly="1" nolabel="1"
                           style="display:inline; color:#842029;"/>
                </div>

                <!-- Banner: listo para timbrar (solo en estado aprobado) -->
                <div class="alert alert-success mb-0"
                     role="status"
                     invisible="not tms_stamp_ready or state != 'aprobado'">
                    <strong>✅ Listo para timbrar.</strong>
                    Presiona "Timbrar Carta Porte" para continuar.
                </div>

                <sheet>
                    <!-- =============================================
                         SMART BUTTONS: Navegación rápida y contadores
                         ============================================= -->
                    <div class="oe_button_box" name="button_box">

                        <!-- Smart Button: Vehículo (visible cuando hay vehículo asignado) -->
                        <button name="action_view_vehicle" type="object" class="oe_stat_button" icon="fa-truck" invisible="not vehicle_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="vehicle_id" readonly="1" nolabel="1" options="{'no_open': True}"/>
                                </span>
                                <span class="o_stat_text">Vehículo</span>
                            </div>
                        </button>

                    </div>

                    <field name="company_id" invisible="1"/>
                    <field name="is_fuel_price_outdated" invisible="1"/>
                    <div class="alert alert-warning" role="alert" invisible="not is_fuel_price_outdated">
                        <strong>AVISO:</strong> No hay precio de diesel reciente (más de 7 días) o no existe historial. Se utiliza el último registro disponible.
                    </div>
                    <div class="d-flex justify-content-between">
                        <div class="oe_title">
                            <label for="name" string="Folio"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <!-- Fechas de embarque/entrega: solo relevantes cuando el viaje ya está en ruta -->
                        <div class="text-center" invisible="state in ['cotizado','aprobado']">
                            <div class="d-flex gap-3">
                                <div>
                                    <label for="date_started_route" string="Fecha Y hora Embarque" class="text-danger fw-bold"/>
                                    <h3 class="m-0">
                                        <field name="date_started_route" widget="datetime" class="text-danger" nolabel="1"/>
                                    </h3>
                                </div>
                                <div>
                                    <label for="date_arrived_dest" string="Fecha y hora de Entrega" class="text-danger fw-bold"/>
                                    <h3 class="m-0">
                                        <field name="date_arrived_dest" widget="datetime" class="text-danger" nolabel="1"/>
                                    </h3>
                                </div>
                            </div>
                        </div>

                        <div class="oe_title text-end">
                            <label for="company_name" string="Empresa"/>
                            <h1>
                                <field name="company_name" readonly="1" class="text-danger"/>
                            </h1>

                        </div>
                    </div>

                    <!-- Datos generales + resumen de precio -->
                    <!-- SECCIÓN DE BÚSQUEDA Y RUTA (OPTIMIZADO PARA ANCHO) -->
                    <!-- DATOS GENERALES Y DETALLES -->
                    <!-- ACTORES DEL VIAJE (HEADER) -->
                    <div class="row mb-3">
                        <div class="col-lg-8">
                            <!-- FACTURACIÓN CARD — readonly cuando el viaje ya está operando -->
                            <div class="card shadow-sm p-3 bg-white" style="border: 1px solid #e0e0e0;">
                                <group string="Facturación" class="mb-0" readonly="state in ['in_transit','arrived','closed','cancel'] or cfdi_status == 'timbrado'">
                                    <field name="date_created" string="Fecha del Pedido" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="partner_invoice_id" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="invoice_rfc" readonly="1"/>
                                    <field name="invoice_address" readonly="1"/>
                                    <field name="company_id" groups="base.group_multi_company" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                                <div class="text-end mt-2" invisible="state in ['in_transit','arrived','closed','cancel']">
                                    <button name="action_clear_facturacion" type="object" icon="fa-trash" title="Limpiar" class="btn btn-link text-danger"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <!-- PRECIO CARD -->
                            <div class="card shadow-sm p-3 bg-white h-100" style="border: 1px solid #e0e0e0;">
                                <group class="mb-0" readonly="cfdi_status == 'timbrado'">
                                    <field name="amount_untaxed" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="amount_tax" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="amount_retention" widget="monetary" options="{'currency_field': 'currency_id'}" class="text-danger" readonly="cfdi_status == 'timbrado'"/>
                                    <label for="amount_total" string="Precio Final"/>
                                    <h2>
                                        <field name="amount_total" decoration-danger="amount_total == 0" readonly="cfdi_status == 'timbrado'"/>
                                    </h2>
                                    <field name="selected_proposal" string="Propuesta" widget="label" class="text-muted" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-lg-6">
                            <!-- ORIGEN CARD -->
                            <div class="card shadow-sm p-3 bg-white h-100" style="border: 1px solid #e0e0e0;">
                                <div class="d-flex align-items-center mb-2" style="border-left: 4px solid #28a745; padding-left: 8px;">
                                    <strong style="font-size: 1.1em;">Origen</strong>
                                </div>
                                <!-- Info mínima: CP + ciudad (visible cuando hay CP) -->
                                <div invisible="not origin_zip" class="mb-2">
                                    <div class="d-flex align-items-center">
                                        <span class="badge text-bg-success me-2">
                                            CP <field name="origin_zip" readonly="1" nolabel="1"/>
                                        </span>
                                        <span class="text-muted">
                                            <field name="origin_city_name" readonly="1" nolabel="1"/>
                                        </span>
                                    </div>
                                </div>
                                <!-- Datos completos: siempre visibles, readonly en estados operativos -->
                                <group class="mb-0" readonly="state in ['in_transit','arrived','closed','cancel'] or cfdi_status == 'timbrado'" invisible="False">
                                    <field name="partner_origin_id" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="origin_address" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <label for="origin_zip"/>
                                    <div class="d-flex align-items-center" invisible="False">
                                        <field name="origin_zip" required="state not in ['cotizado', 'aprobado']" class="me-2" style="max-width: 100px;" readonly="cfdi_status == 'timbrado'"/>
                                        <field name="origin_city_name" readonly="1" nolabel="1" class="text-muted fst-italic"/>
                                    </div>
                                    <field name="origin_rfc" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                                <div class="text-end mt-2" invisible="state in ['cotizado', 'in_transit','arrived','closed','cancel']">
                                    <button name="action_clear_origen" type="object" icon="fa-trash" title="Limpiar" class="btn btn-link text-danger"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <!-- DESTINO CARD -->
                            <div class="card shadow-sm p-3 bg-white h-100" style="border: 1px solid #e0e0e0;">
                                <div class="d-flex align-items-center mb-2" style="border-left: 4px solid #dc3545; padding-left: 8px;">
                                    <strong style="font-size: 1.1em;">Destino</strong>
                                </div>
                                <!-- Info mínima: CP + ciudad (visible cuando hay CP) -->
                                <div invisible="not dest_zip" class="mb-2">
                                    <div class="d-flex align-items-center">
                                        <span class="badge text-bg-danger me-2">
                                            CP <field name="dest_zip" readonly="1" nolabel="1"/>
                                        </span>
                                        <span class="text-muted">
                                            <field name="dest_city_name" readonly="1" nolabel="1"/>
                                        </span>
                                    </div>
                                </div>
                                <!-- Datos completos: siempre visibles, readonly en estados operativos -->
                                <group class="mb-0" readonly="state in ['in_transit','arrived','closed','cancel'] or cfdi_status == 'timbrado'" invisible="False">
                                    <field name="partner_dest_id" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="dest_address" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <label for="dest_zip"/>
                                    <div class="d-flex align-items-center" invisible="False">
                                        <field name="dest_zip" required="state not in ['cotizado', 'aprobado']" class="me-2" style="max-width: 100px;" readonly="cfdi_status == 'timbrado'"/>
                                        <field name="dest_city_name" readonly="1" nolabel="1" class="text-muted fst-italic"/>
                                    </div>
                                    <field name="dest_rfc" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                                <div class="text-end mt-2" invisible="state in ['cotizado', 'in_transit','arrived','closed','cancel']">
                                    <button name="action_clear_destino" type="object" icon="fa-trash" title="Limpiar" class="btn btn-link text-danger"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <notebook>
                        <!-- ======================= -->
                        <!-- INFO GENERAL -->
                        <!-- ======================= -->
                        <!-- ======================= -->
                        <!-- INFORMACIÓN DE RUTA    -->
                        <!-- ======================= -->
                        <page string="Información de Ruta">
                            <group readonly="cfdi_status == 'timbrado'">
                                <group>
                                    <field name="waybill_type" widget="radio" options="{'horizontal': True}" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                            </group>

                            <!-- UNIDAD ASIGNADA — readonly cuando el viaje ya está en ruta -->
                            <group string="Unidad Asignada" invisible="state == 'cotizado'" readonly="state in ['in_transit','arrived','closed','cancel'] or cfdi_status == 'timbrado'">
                                <group>
                                    <field name="vehicle_id" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="require_trailer" widget="boolean_toggle" string="Lleva Remolque" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="trailer1_id" invisible="not require_trailer" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="dolly_id" invisible="not require_trailer" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                                <group>
                                    <field name="driver_id" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="trailer2_id" widget="many2one" placeholder="Segundo Remolque (Opcional)" invisible="not require_trailer" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="total_axles" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                            </group>

                            <!-- DETALLES DE RUTA — readonly cuando el viaje ya está en ruta -->
                            <group string="Detalles de Ruta" readonly="state in ['in_transit','arrived','closed','cancel'] or cfdi_status == 'timbrado'">
                                <group>
                                    <field name="distance_km" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="duration_hours" widget="float_time" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_tolls" required="state not in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                                <group>
                                    <label for="action_compute_route_smart" string="Cálculo" invisible="state in ['in_transit','arrived','closed','cancel']"/>
                                    <div class="o_row" invisible="state in ['in_transit','arrived','closed','cancel']">
                                        <button name="action_compute_route_smart" type="object" string=" Calcular Ruta (Smart)" icon="fa-magic" class="btn btn-primary"/>
                                        <div class="text-muted ms-2">
                                            <i class="fa fa-info-circle"/>
 Calcula distancia y casetas basado en Origen/Destino y Vehículo.
                                        </div>
                                    </div>
                                </group>
                            </group>
                        </page>

                        <!-- ======================= -->
                        <!-- COTIZACIÓN Y COSTOS (SIEMPRE VISIBLE) -->
                        <!-- ======================= -->
                        <!-- Pestaña de cotización: readonly en estados operativos/finales -->
                        <page string="Cotización y Costos" readonly="state in ['in_transit','arrived','closed','cancel'] or cfdi_status == 'timbrado'">

                            <!-- SECCIÓN 1: COSTOS OPERATIVOS -->
                            <group string="⛽ COSTOS OPERATIVOS">
                                <p class="text-muted ms-2" colspan="2">
                                    <i class="fa fa-info-circle"/>
 Usados para calcular Propuesta B
                                </p>
                                <group>
                                    <field name="fuel_price_liter" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_driver" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_other" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_diesel_total" readonly="1"/>
                                </group>
                                <group>
                                    <field name="fuel_performance" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_maneuver" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_commission" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="cost_total_estimated" decoration-bf="1" readonly="1"/>
                                </group>
                            </group>

                            <!-- SECCIÓN 2: PRECIO POR KILÓMETRO -->
                            <group string="📐 PRECIO POR KILÓMETRO">
                                <p class="text-muted ms-2" colspan="2">
                                    <i class="fa fa-info-circle"/>
 Usado para calcular Propuesta A
                                </p>
                                <group>
                                    <field name="price_per_km" readonly="cfdi_status == 'timbrado'"/>
                                    <label for="distance_km" string="Distancia Base"/>
                                    <div class="o_row">
                                        <field name="distance_km" class="oe_inline" readonly="1"/>
 km
                                    </div>
                                </group>
                                <group>
                                    <field name="profit_margin_percent" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="extra_distance_km" string="Km Extras" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                            </group>

                            <!-- SECCIÓN 3: PRECIO DIRECTO -->
                            <group string="💰 PRECIO DIRECTO">
                                <p class="text-muted ms-2" colspan="2">
                                    <i class="fa fa-info-circle"/>
 Propuesta C — tarifa fija
                                </p>
                                <group>
                                    <field name="proposal_direct_amount" string="Precio Directo" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                            </group>

                            <!-- SECCIÓN 4: COMPARATIVA DE PROPUESTAS -->
                            <group string="🚛 COMPARATIVA DE PROPUESTAS">
                                <group col="3">
                                    <group string="A — Por KM">
                                        <field name="proposal_km_total" nolabel="1" readonly="1" decoration-bf="1" class="fs-5"/>
                                    </group>
                                    <group string="B — Por Viaje">
                                        <field name="proposal_trip_total" nolabel="1" readonly="1" decoration-bf="1" class="fs-5"/>
                                    </group>
                                    <group string="C — Directo">
                                        <field name="proposal_direct_amount" nolabel="1" readonly="1" decoration-bf="1" class="fs-5"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="selected_proposal" widget="radio" options="{'horizontal': true}" readonly="cfdi_status == 'timbrado'"/>
                                    <button name="action_apply_proposal" string="Aplicar Propuesta" type="object" class="btn-primary mt-2" icon="fa-check-circle" help="Actualiza el subtotal con el valor de la propuesta seleccionada."/>
                                </group>
                            </group>
                        </page>

                        <!-- ======================= -->
                        <!-- CARTA PORTE 3.1 -->
                        <!-- ======================= -->
                        <!-- Carta Porte: no tiene sentido en borrador (sin info completa aún) -->
                        <page string="Complemento Carta Porte 3.1" name="carta_porte_31" invisible="state in ['cotizado', 'aprobado']" readonly="cfdi_status == 'timbrado'">
                            <group>
                                <group string="Identificación">
                                    <!-- IdCCP: campo interno, se genera automáticamente, no se muestra al usuario -->
                                    <field name="tms_id_ccp" invisible="1"/>
                                    <field name="l10n_mx_edi_is_international" widget="boolean_toggle" readonly="cfdi_status == 'timbrado'"/>
                                    <field name="l10n_mx_edi_logistica_inversa" widget="boolean_toggle" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                                <group string="Autotransporte">
                                    <field name="tms_gross_vehicle_weight" string="Peso Bruto (Ton)" readonly="cfdi_status == 'timbrado'"/>
                                </group>
                            </group>

                            <group string="Regímenes Aduaneros (Hasta 10)" invisible="not l10n_mx_edi_is_international">
                                <field name="l10n_mx_edi_customs_regime_ids" nolabel="1" readonly="cfdi_status == 'timbrado'">
                                    <list editable="bottom">
                                        <field name="regimen_aduanero"/>
                                    </list>
                                </field>
                            </group>

                            <!-- ════════════════════════════════════════════════════
                                 TIMBRE FISCAL DIGITAL — Visible cuando se ha timbrado
                                 ════════════════════════════════════════════════════ -->
                            <group string="Timbre Fiscal Digital" invisible="cfdi_status == 'none'">
                                <group>
                                    <field name="cfdi_uuid"        string="UUID CFDI"            readonly="1"/>
                                    <field name="cfdi_fecha"       string="Fecha de timbrado"     readonly="1"/>
                                    <field name="cfdi_pac"         string="PAC"                   readonly="1"/>
                                    <field name="cfdi_no_cert_sat" string="No. Certificado SAT"   readonly="1"/>
                                </group>
                                <group>
                                    <field name="cfdi_status"      string="Estatus CFDI"          readonly="1"
                                           widget="badge"
                                           decoration-success="cfdi_status == 'timbrado'"
                                           decoration-danger="cfdi_status in ('cancelado','error')"
                                           decoration-muted="cfdi_status == 'none'"/>
                                    <field name="cfdi_error_msg"   string="Último error"          readonly="1"
                                           invisible="cfdi_status not in ('error',)"/>
                                </group>
                            </group>
                        </page>

                        <!-- ======================= -->
                        <!-- MERCANCÍAS             -->
                        <!-- ======================= -->
                        <page string="Mercancías">
                            <field name="has_dangerous_lines" invisible="1"/>
                            <field name="line_ids" readonly="cfdi_status == 'timbrado'">
                                <list editable="bottom">
                                    <field name="product_sat_id" string="Clave SAT"
                                           decoration-danger="not product_sat_id"/>
                                    <field name="description" string="Descripción"/>
                                    <field name="quantity" string="Cant."/>
                                    <field name="uom_sat_id" string="Unidad"
                                           decoration-danger="not uom_sat_id"/>
                                    <field name="dim_largo" string="↔ Lrg"/>
                                    <field name="dim_ancho" string="↕ Anc"/>
                                    <field name="dim_alto"  string="↑ Alt"/>
                                    <field name="dimensions" column_invisible="1"/>
                                    <field name="weight_kg" string="Peso Kg"/>
                                    <field name="is_dangerous" string="¿Pel.?"/>
                                    <field name="embalaje_id" string="Embalaje"/>
                                    <field name="material_peligroso_id" string="Mat. Pelig." column_invisible="not parent.has_dangerous_lines" invisible="not is_dangerous" required="is_dangerous"/>
                                    <field name="l10n_mx_edi_sector_cofepris" string="Sec. COF." column_invisible="not parent.has_dangerous_lines" invisible="not is_dangerous"/>
                                    <field name="l10n_mx_edi_active_ingredient" string="Ing. Act." column_invisible="not parent.has_dangerous_lines" invisible="not is_dangerous"/>
                                    <field name="l10n_mx_edi_nominal_purity" string="Pur. Nom." column_invisible="not parent.has_dangerous_lines" invisible="not is_dangerous"/>
                                    <field name="l10n_mx_edi_tax_object" string="Obj. Imp." optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <!-- ======================= -->
                        <!-- BITÁCORA GPS           -->
                        <!-- ======================= -->
                        <!-- Bitácora GPS: solo relevante cuando el viaje ya salió (desde estado waybill) -->
                        <page string="Bitácora GPS" invisible="state in ['cotizado','aprobado']">
                            <field name="tracking_event_ids">
                                <list string="Eventos de Rastreo" editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="location_description"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                    <field name="source" widget="badge" decoration-info="source == 'app'" decoration-muted="source == 'manual'"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                                <form string="Evento de Rastreo">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="date"/>
                                                <field name="name"/>
                                                <field name="source"/>
                                            </group>
                                            <group>
                                                <field name="latitude"/>
                                                <field name="longitude"/>
                                                <field name="location_description"/>
                                            </group>
                                        </group>
                                        <field name="notes" placeholder="Notas adicionales..."/>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <!-- ======================= -->
                        <!-- FIRMA DIGITAL          -->
                        <!-- ======================= -->
                        <page string="Firma Digital" invisible="not signature">
                            <group>
                                <group string="Detalles de la Firma">
                                    <field name="signed_by" readonly="1"/>
                                    <field name="signed_on" readonly="1"/>
                                    <field name="signed_ip" readonly="1"/>
                                    <label for="signed_latitude" string="Ubicación Firma"/>
                                    <div class="o_row">
                                        <field name="signed_latitude" readonly="1" class="oe_inline"/>
 /
                                        <field name="signed_longitude" readonly="1" class="oe_inline"/>
                                        <a type="action" class="btn btn-sm btn-link" role="button" target="_blank" href="https://www.google.com/maps/search/?api=1&amp;query={{signed_latitude}},{{signed_longitude}}" invisible="not signed_latitude">
                                            <i class="fa fa-map-marker"/>
 Ver en Mapa
                                        </a>
                                    </div>
                                </group>
                                <group string="Imagen de Firma">
                                    <field name="signature" widget="signature" readonly="1" style="max-height: 200px;"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- ======================= -->
    <!-- SEARCH Y ACTION -->
    <!-- ======================= -->
    <record id="view_tms_waybill_search" model="ir.ui.view">
        <field name="name">tms.waybill.search</field>
        <field name="model">tms.waybill</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_invoice_id"/>
                <!-- Filtros individuales por los 6 estados del flujo V2.5 -->
                <filter name="filter_cotizado"   string="Cotizado"     domain="[('state', '=', 'cotizado')]"/>
                <filter name="filter_aprobado"   string="Aprobado"     domain="[('state', '=', 'aprobado')]"/>
                <filter name="filter_waybill"    string="Carta Porte"  domain="[('state', '=', 'waybill')]"/>
                <filter name="filter_in_transit" string="En Tránsito"  domain="[('state', '=', 'in_transit')]"/>
                <filter name="filter_arrived"    string="En Destino"   domain="[('state', '=', 'arrived')]"/>
                <filter name="filter_closed"     string="Facturado"    domain="[('state', '=', 'closed')]"/>
            </search>
        </field>
    </record>

    <record id="action_tms_waybill" model="ir.actions.act_window">
        <field name="name">Viajes / Tablero</field>
        <field name="res_model">tms.waybill</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_tms_waybill_search"/>
        <!-- Domain fijo: excluye estados internos del tablero. El kanban usa su propio
             default_group_by="state" (no expand=True), así las columnas vacías no aparecen. -->
        <field name="domain">[('state', 'not in', ['rejected','cancel'])]</field>
        <field name="context">{}</field>
    </record>

</odoo>
