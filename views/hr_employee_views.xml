<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        ================================================================
        VISTA FORM SIMPLIFICADA PARA CHOFERES (TMS)
        ================================================================
    -->
    <record id="view_tms_driver_form" model="ir.ui.view">
        <field name="name">tms.hr.employee.driver.form</field>
        <field name="model">hr.employee</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Chofer / Operador">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre completo del Chofer"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos de Operación">
                            <field name="tms_is_driver" invisible="1"/>
                            <field name="work_contact_id" string="Contacto Fiscal" required="1"/>
                            <field name="tms_driver_license_type" required="1"/>
                            <field name="tms_driver_license" required="1"/>
                            <field name="tms_driver_license_expiration"/>
                        </group>
                        <group string="Validación SAT (Carta Porte)">
                            <field name="tms_driver_rfc"/>
                            <field name="l10n_mx_edi_fiscal_regime" required="1"/>
                            <field name="tms_driver_address" string="Domicilio Fiscal"/>
                            <div class="alert alert-info" role="alert" invisible="tms_driver_rfc and tms_driver_address">
                                <strong>Nota:</strong> Los datos fiscales se sincronizan desde el <i>Contacto Fiscal</i> seleccionado a la izquierda.
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VISTA LIST SIMPLIFICADA PARA CHOFERES -->
    <record id="view_tms_driver_list" model="ir.ui.view">
        <field name="name">tms.hr.employee.driver.list</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <list string="Choferes">
                <field name="name"/>
                <field name="tms_driver_license"/>
                <field name="tms_driver_license_type"/>
                <field name="tms_driver_rfc"/>
                <field name="tms_driver_license_expiration" widget="remaining_days"/>
            </list>
        </field>
    </record>
</odoo>
