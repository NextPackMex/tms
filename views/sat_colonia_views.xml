<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Tree: Colonias -->
    <record id="view_sat_colonia_tree" model="ir.ui.view">
        <field name="name">tms.sat.colonia.tree</field>
        <field name="model">tms.sat.colonia</field>
        <field name="arch" type="xml">
            <list string="Colonias SAT">
                <!-- Columna: Código Postal -->
                <field name="zip_code"/>

                <!-- Columna: Nombre de Colonia -->
                <field name="name"/>

                <!-- Columna: Código SAT de Colonia -->
                <field name="code"/>
            </list>
        </field>
    </record>

    <!-- Vista Search: Colonias -->
    <!--
    <record id="view_sat_colonia_search" model="ir.ui.view">
        <field name="name">tms.sat.colonia.search</field>
        <field name="model">tms.sat.colonia</field>
        <field name="arch" type="xml">
            <search string="Buscar Colonia">
                <field name="zip_code"/>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>
    -->

    <!-- Action: Colonias -->
    <record id="action_sat_colonia" model="ir.actions.act_window">
        <field name="name">Colonias SAT</field>
        <field name="res_model">tms.sat.colonia</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay colonias cargadas
            </p>
            <p>
                Usa el wizard de importación para cargar el catálogo de colonias desde Excel.
            </p>
        </field>
    </record>

</odoo>

